# --- App runtime ---
APP_ENV=development
HOST=127.0.0.1
PORT=8000
LAUNCHSHIELD_DATA_DIR=data
LAUNCHSHIELD_DEMO_PACE_SECONDS=0.35

# --- Browser runtime ---
CHROME_DEBUG_URL=http://127.0.0.1:9222
USE_REAL_BROWSER=false

# --- GitHub ---
USE_REAL_GITHUB=false
GITHUB_TOKEN=

# --- LLM ---
USE_REAL_LLM=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- AIsa ---
USE_REAL_AISA=false
AISA_API_KEY=
AISA_BASE_URL=

# --- Circle / Arc testnet payments ---
USE_REAL_PAYMENTS=false
CIRCLE_API_KEY=

# Arc testnet defaults (https://docs.arc.network). Override only if you must.
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_EXPLORER_BASE_URL=https://testnet.arcscan.app

# Wallet credentials. Generate with `cast wallet new`, fund at https://faucet.circle.com.
# ARC_WALLET_ADDRESS is optional; we derive it from ARC_PRIVATE_KEY at startup.
ARC_WALLET_ADDRESS=
ARC_PRIVATE_KEY=

# Optional: route payments to a "merchant" address. Defaults to a self-transfer
# (wallet sends to itself), which still produces a real on-chain tx for the demo.
ARC_MERCHANT_ADDRESS=

# Optional: cap every transfer at a fixed USDC amount instead of the listed tool
# price (useful when you want to stretch faucet funds across many demo runs).
ARC_PAYMENT_AMOUNT_OVERRIDE_USDC=

# Receipt timeout per transfer.
ARC_TX_TIMEOUT_SECONDS=45

# Optional alternate path: hosted x402 / Circle Gateway. Used only if
# ARC_PRIVATE_KEY is empty AND both of these are set.
X402_GATEWAY_BASE_URL=
X402_GATEWAY_API_KEY=

# --- Preset demo target ---
PRESET_REPO_URL=https://github.com/launchshield-demo/vulnerable-playground
PRESET_TARGET_URL=https://vulnerable-playground.launchshield.dev
